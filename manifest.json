{
  "manifest_version": 3,
  "name": "Memoria",
  "version": "1.0",
  "description": "Tiện ích cá nhân với Ghi chú, Lịch trình, Clipboard & AI Chatbot",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "sidePanel",
    "scripting",
    "notifications",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Mở Side Panel Memoria"
  },
  "side_panel": {
    "default_path": "ui/sidepanel.html"
  },
  "options_page": "ui/settings.html"
}
