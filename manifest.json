{
  "manifest_version": 3,
  "name": "Memoria",
  "version": "1.0",
  "description": "Memoria - Trợ lý ảo toàn diện với AI, Quản lý Lịch trình, Ghi chú và Clipboard thông minh",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "offscreen",
    "sidePanel",
    "scripting",
    "notifications",
    "idle",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/modules/clipboard.js",
        "content/modules/reminder.js",
        "content/modules/translate.js",
        "content/modules/allowCopy.js",
        "content/modules/ocr-translate.js"
      ]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Mở Side Panel Memoria"
  },
  "side_panel": {
    "default_path": "ui/sidepanel.html"
  },
  "options_page": "ui/settings.html",
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "lib/tesseract/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
